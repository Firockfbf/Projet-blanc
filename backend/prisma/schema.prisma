// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SCHOOL
}

enum StudentStatus {
  PENDING
  ADMITTED
  FAILED
}

model Subscription {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  monthlyPrice Float
  maxStudents  Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  schools      School[]
}

model School {
  id             String        @id @default(cuid())
  name           String
  email          String        @unique
  city           String?
  country        String        @default("France")
  active         Boolean       @default(true)
  subscriptionId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  users          User[]
  formations     Formation[]
  students       Student[]
  certificates   Certificate[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role     @default(SCHOOL)
  isActive     Boolean  @default(true)
  schoolId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  school       School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model Formation {
  id        String    @id @default(cuid())
  name      String
  code      String
  year      String    @default("2025-2026")
  schoolId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students  Student[]

  @@unique([schoolId, code, year])
}

model Student {
  id             String        @id @default(cuid())
  firstName      String
  lastName       String
  email          String
  schoolId       String
  formationId    String?
  status         StudentStatus @default(PENDING)
  passed         Boolean       @default(false)
  certified      Boolean       @default(false)
  graduationYear String        @default("2026")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  formation      Formation?    @relation(fields: [formationId], references: [id], onDelete: SetNull)
  certificates   Certificate[]

  @@unique([schoolId, email])
}

model CertificateTemplate {
  id           String        @id @default(cuid())
  name         String        @unique
  title        String
  signerName   String
  signerRole   String
  footerText   String
  accentColor  String        @default("#14532d")
  isDefault    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  certificates Certificate[]
}

model Certificate {
  id              String               @id @default(cuid())
  code            String               @unique
  studentId       String
  schoolId        String
  templateId      String?
  verificationUrl String
  qrCodeDataUrl   String
  issuedAt        DateTime             @default(now())
  student         Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school          School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  template        CertificateTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
}
